# ── Frontend (Supabase cliente) ──
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── RisePay (servidor: .env local ou Vercel Environment Variables) ──
# Token privado — NUNCA use prefixo VITE_
RISEPAY_SECRET=

# URL pública do postback (mesma base do site). A API de PIX envia isso em cada cobrança.
# Ex.: https://seu-app.vercel.app/api/risepay-webhook
RISEPAY_POSTBACK_URL=

# ── Supabase só servidor (webhook + consulta de status) — NUNCA no frontend ──
# Mesmo projeto do VITE_SUPABASE_URL (pode repetir o valor aqui).
SUPABASE_URL=
# Project Settings → API → service_role (bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: no painel RisePay, registre também um webhook apontando para:
#   https://SEU_DOMINIO/api/risepay-webhook
